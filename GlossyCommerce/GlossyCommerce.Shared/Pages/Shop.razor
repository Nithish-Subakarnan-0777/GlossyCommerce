@page "/"
@rendermode InteractiveServer
@using GlossyCommerce.Shared.Models
@using GlossyCommerce.Shared.Services
@inject HttpClient Http
@inject CartService Cart
@inject NavigationManager Nav

<PageTitle>Shop - GlossyCommerce</PageTitle>

<div class="shop-header">
    <h2>Trending Products</h2>
    <div class="cart-summary glossy-card">
        🛒 Cart: @Cart.CartItems.Sum(c => c.Quantity) items | Total: $@Cart.GetTotal().ToString("0.00")
        @if(Cart.CartItems.Any())
        {
            <button class="glossy-button checkout-btn" @onclick="GoToCheckout">Checkout</button>
        }
    </div>
</div>

@if (products == null)
{
    <p><em>Loading premium products...</em></p>
}
else if (!products.Any())
{
    <p>No products available yet. Waiting for admin to upload some!</p>
}
else
{
    <div class="product-grid">
        @foreach (var product in products)
        {
            <div class="glossy-card product-card">
                <img src="@(string.IsNullOrEmpty(product.ImageUrl) ? "https://via.placeholder.com/300x200" : product.ImageUrl)" alt="@product.Name" class="product-img" />
                
                <div class="product-info">
                    <h3>@product.Name</h3>
                    <p class="description">@product.Description</p>
                    <p class="price">$@product.Price.ToString("0.00")</p>
                    
                    <button class="glossy-button w-100" @onclick="() => AddToCart(product)">
                        Add to Cart
                    </button>
                </div>
            </div>
        }
    </div>
}

<style>
    .shop-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 30px;
    }
    
    .cart-summary {
        padding: 12px 24px;
        display: flex;
        align-items: center;
        gap: 15px;
        font-weight: 600;
    }

    .checkout-btn {
        padding: 8px 16px;
        font-size: 0.9rem;
    }

    .product-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 24px;
    }

    .product-card {
        padding: 0;
        overflow: hidden;
        display: flex;
        flex-direction: column;
    }

    .product-img {
    width: 100%;
    height: 220px; /* Slightly taller for a premium look */
    object-fit: cover; /* This forces the image to perfectly fill the box without stretching */
    object-position: center; /* Keeps the main subject in the middle */
    border-radius: 20px 20px 0 0; /* Perfectly matches the top corners of your glossy-card */
    border-bottom: 1px solid var(--glass-border);
    }

    .product-info {
        padding: 20px;
        display: flex;
        flex-direction: column;
        flex-grow: 1;
    }

    .product-info h3 { margin: 0 0 10px 0; font-size: 1.2rem; }
    .description { color: var(--text-secondary); font-size: 0.9rem; flex-grow: 1; margin-bottom: 15px; }
    .price { font-size: 1.3rem; font-weight: 700; color: #007aff; margin-bottom: 15px; }
    .w-100 { width: 100%; }
</style>

@code {
    private List<Product>? products;

    protected override async Task OnInitializedAsync()
    {
        // Fetch products from our SSMS database via the API we built earlier
        try 
        {
            // Note: We'll set up the base address for HttpClient shortly
            products = await Http.GetFromJsonAsync<List<Product>>("api/products");
            
            // Subscribe to cart changes so the UI updates automatically
            Cart.OnCartChanged += StateHasChanged;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error fetching products: {ex.Message}");
            products = new List<Product>(); 
        }
    }

    private void AddToCart(Product product)
    {
        Cart.AddToCart(product);
    }

    private void GoToCheckout()
    {
        Nav.NavigateTo("/checkout");
    }

    public void Dispose()
    {
        Cart.OnCartChanged -= StateHasChanged;
    }
}
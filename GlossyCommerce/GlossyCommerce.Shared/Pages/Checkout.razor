@page "/checkout"
@rendermode InteractiveServer
@using GlossyCommerce.Shared.Models
@using GlossyCommerce.Shared.Services
@inject CartService Cart
@inject HttpClient Http
@inject NavigationManager Nav
@inject AuthService Auth

<PageTitle>Checkout - GlossyCommerce</PageTitle>

@if (Auth.CurrentUser == null)
{
    <div class="glossy-card text-center" style="margin: 100px auto; max-width: 400px;">
        <h3>Almost there!</h3>
        <p>You need to be logged in to complete your secure checkout.</p>
        <button class="glossy-button mt-3" @onclick='() => Nav.NavigateTo("/login")'>Go to Login</button>
    </div>
}
else
{
    <div class="checkout-container">
        <div class="checkout-form glossy-card">
            <h2>Secure Checkout</h2>
            <p>Complete your order details below, <b>@Auth.CurrentUser.Username</b>.</p>

            @if (!Cart.CartItems.Any())
            {
                <div class="alert">Your cart is empty! Go back to the shop to add items.</div>
                <button class="glossy-button mt-3" @onclick='() => Nav.NavigateTo("/")'>Return to Shop</button>
            }
            else
            {
                <EditForm Model="@order" OnValidSubmit="SubmitOrder">
                    <DataAnnotationsValidator />

                    <div class="form-group">
                        <label>Full Name</label>
                        <InputText @bind-Value="order.CustomerName" class="glossy-input w-100" placeholder="John Doe" required />
                    </div>

                    <div class="form-group">
                        <label>Email Address</label>
                        <InputText @bind-Value="order.ContactEmail" type="email" class="glossy-input w-100" placeholder="john@example.com" required />
                    </div>

                    <div class="form-group">
                        <label>Phone Number</label>
                        <InputText @bind-Value="order.ContactPhone" class="glossy-input w-100" placeholder="+1 234 567 8900" required />
                    </div>

                    <div class="form-group">
                        <label>Shipping Address</label>
                        <InputTextArea @bind-Value="order.ShippingAddress" class="glossy-input w-100" rows="3" placeholder="123 Glossy Street..." required />
                    </div>
                    <div class="mt-4 mb-4" style="border-top: 1px solid var(--glass-border); padding-top: 20px;">
                       <h4>Your Cart Items</h4>
                        @foreach(var item in Cart.CartItems)
                        {
                            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 10px;">
                                <span>@item.Product?.Name (x @item.Quantity) - $@(item.UnitPrice * item.Quantity)</span>
        
                                <span style="cursor:pointer; color: var(--neon-pink); font-weight: bold;" @onclick="() => Cart.RemoveFromCart(item.ProductId)">✕ Remove</span>
                            </div>
                        }
                </div>

                    <div class="order-summary mt-4">
                        <h4>Order Total: $@Cart.GetTotal().ToString("0.00")</h4>
                    </div>

                    <button type="submit" class="glossy-button w-100 mt-4" disabled="@isSubmitting">
                        @(isSubmitting ? "Processing..." : "Place Order")
                    </button>
                </EditForm>
            }
        </div>
    </div>
}

<style>
    .checkout-container { max-width: 600px; margin: 0 auto; padding: 20px; }
    .checkout-form { padding: 40px; }
    .form-group { margin-bottom: 20px; text-align: left; }
    .form-group label { display: block; margin-bottom: 8px; font-weight: 500; color: var(--text-secondary); }
    .w-100 { width: 100%; box-sizing: border-box; }
    .mt-3 { margin-top: 15px; }
    .mt-4 { margin-top: 25px; }
    .alert { padding: 15px; background: rgba(255, 59, 48, 0.1); color: #ff3b30; border-radius: 8px; border: 1px solid rgba(255, 59, 48, 0.3); }
</style>

@code {
    private Order order = new Order();
    private bool isSubmitting = false;

    protected override void OnInitialized()
    {
        order.TotalAmount = Cart.GetTotal();
    }

    private async Task SubmitOrder()
    {
        isSubmitting = true;
        try
        {
            order.OrderItems = Cart.CartItems.Select(item => new OrderItem
            {
                ProductId = item.ProductId,
                Quantity = item.Quantity,
                UnitPrice = item.UnitPrice
            }).ToList();

            var response = await Http.PostAsJsonAsync("api/orders", order);

            if (response.IsSuccessStatusCode)
            {
                Cart.ClearCart();
                Nav.NavigateTo("/confirmation");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error: {ex.Message}");
        }
        finally
        {
            isSubmitting = false;
        }
    }
}